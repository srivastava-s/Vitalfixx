# ── VitalFix Environment Variables ──

# PSI Key Pool — comma-separated for round-robin rotation
# Get keys at: https://console.cloud.google.com/apis/credentials
PSI_API_KEYS_POOL=your_key_1,your_key_2,your_key_3

# Legacy single key (fallback if PSI_API_KEYS_POOL is empty)
GOOGLE_PSI_API_KEY=your_single_key

# ── Supabase (Auth + Cloud Persistence) ──
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Sentry (Error Monitoring + Tracing) ──
# Get your DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
# Auth token for source map uploads (keep secret, do not commit)
# SENTRY_AUTH_TOKEN=sntrys_eyJ...

# ── Stripe (Payments) ──
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Create price IDs in Stripe Dashboard → Products
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_PRO_YEARLY_PRICE_ID=price_your_yearly_price_id

# ── Supabase Service Role (server-side only, DO NOT expose to client) ──
# Used by webhook handler to bypass RLS
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
